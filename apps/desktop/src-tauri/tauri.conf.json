{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "微信助手",
  "version": "0.1.0",
  "identifier": "com.wechat-agent-kit.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "微信助手",
        "width": 960,
        "height": 720,
        "minWidth": 900,
        "minHeight": 660,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
